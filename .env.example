# ───────────────────────────────────────────────────────────────────────────
# STRIKE SOL environment
# Copy to .env.local and fill in. All NEXT_PUBLIC_* vars are exposed to the browser.
# ───────────────────────────────────────────────────────────────────────────

# Solana cluster the app trades against: "mainnet-beta" | "devnet"
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Solana RPC (public endpoints are heavily rate-limited — use Helius/Triton/QuickNode for live
# trading). Exposed to the client for the Drift SDK.
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Optional server-only RPC override for the read routes (balance reads, etc.).
# SOLANA_RPC=

# Trading mode:
#   "paper" — local bankroll, real prices, NO on-chain settlement (default; safe demo)
#   "live"  — real Drift perps signed by the user's Privy Solana wallet
NEXT_PUBLIC_STRIKE_MODE=paper

# Market the tap screen trades. One of the keys in lib/drift/networks.ts MARKETS.
NEXT_PUBLIC_MARKET=BTC/USD

# Chart/settlement price source: "pyth" (default; matches Drift's oracle) | "binance" (smoother
# but drifts from the on-chain fill — demo aesthetics only).
NEXT_PUBLIC_PRICE_FEED=pyth

# STRIKE platform fee, charged on the STAKE per call (default 0.0069 = 0.69%). And the treasury
# (Solana base58) that receives it on-chain in live mode. Leave the treasury blank to charge no fee.
NEXT_PUBLIC_STRIKE_FEE_RATE=0.0069
NEXT_PUBLIC_STRIKE_TREASURY=

# Privy 𝕏 OAuth login. When set, real X login activates and a Solana embedded wallet is created on
# login; otherwise a prototype handle-entry flow is used. Create at dashboard.privy.io → enable
# Twitter login → add your domains to "Allowed origins", and enable Solana embedded wallets.
NEXT_PUBLIC_PRIVY_APP_ID=

# GO-LIVE GATE. Even in mode "live", NO transaction is broadcast unless this is exactly "true".
# Lets you wire + dry-run the whole live path (build + Privy sign) against a funded wallet before
# any real send. Flip to "true" only when you are ready to trade for real.
NEXT_PUBLIC_STRIKE_LIVE_BROADCAST=false

# Optional: an authenticated Drift Data API key to power the community trade tape + leaderboard.
# Without it the tape stays quiet (mainnet trades are sparse anyway) and the game still works.
# DRIFT_DATA_API_KEY=
